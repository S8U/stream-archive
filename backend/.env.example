# Spring Profile Configuration
SPRING_PROFILES_ACTIVE=local

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=stream_archive
DB_USERNAME=stream_archive_app
DB_PASSWORD=password

# Server Configuration
SERVER_PORT=8080

# Base URL Configuration
API_BASE_URL=http://localhost:8080
FRONTEND_BASE_URL=http://localhost:3000

# Cookie Configuration
COOKIE_DOMAIN=localhost

# Admin Configuration
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Storage Configuration
STORAGE_BASE_PATH=./storage

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_minimum_256_bits_required_for_hs256_algorithm

# Twitch Platform Configuration
TWITCH_APP_CLIENT_ID=your_client_id
TWITCH_APP_CLIENT_SECRET=your_client_secret
TWITCH_PERSONAL_OAUTH_TOKEN=your_personal_token